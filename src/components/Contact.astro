---
---

<section id="contact" class="pt-24 pb-24 bg-black">
  <div class="container mx-auto px-6 max-w-2xl text-center">
    <h1 class="text-5xl md:text-7xl font-black tracking-tighter mb-4">FOLLOW US</h1>
    <p class="text-lg text-gray-400 mb-16">
      Stay connected with SouthLight Pictures.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-8">
      <!-- Instagram -->
      <a
        href="https://instagram.com/southlightpictures"
        target="_blank"
        rel="noopener noreferrer"
        class="flex flex-col items-center gap-3 text-gray-400 hover:text-white transition-colors group"
      >
        <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
        <span class="text-sm font-medium tracking-wider uppercase">Instagram</span>
      </a>

      <!-- Email -->
      <a
        href="mailto:info@southlightpictures.com"
        class="flex flex-col items-center gap-3 text-gray-400 hover:text-white transition-colors group"
      >
        <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
        </svg>
        <span class="text-sm font-medium tracking-wider uppercase">Email</span>
      </a>

      <!-- YouTube -->
      <a
        href="https://youtube.com/@southlightpictures"
        target="_blank"
        rel="noopener noreferrer"
        class="flex flex-col items-center gap-3 text-gray-400 hover:text-white transition-colors group"
      >
        <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
          <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
        <span class="text-sm font-medium tracking-wider uppercase">YouTube</span>
      </a>

      <!-- X / Twitter -->
      <a
        href="https://x.com/southlightpics"
        target="_blank"
        rel="noopener noreferrer"
        class="flex flex-col items-center gap-3 text-gray-400 hover:text-white transition-colors group"
      >
        <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
        <span class="text-sm font-medium tracking-wider uppercase">X</span>
      </a>
    </div>
  </div>
</section>
