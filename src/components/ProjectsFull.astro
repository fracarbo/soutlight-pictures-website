---
import { projects } from '../data/projects';
---

<section class="bg-black pt-24">
  <div class="mb-16 px-6 container mx-auto">
    <h1 class="text-5xl md:text-7xl font-black tracking-tighter mb-4">OUR WORK</h1>
    <p class="text-xl text-gray-400">Every project tells a story</p>
  </div>

  <div class="space-y-1">
    {projects.map((project, index) => (
      <div
        class="group relative overflow-hidden cursor-pointer h-96 md:h-[500px] project-card"
        data-index={index}
        role="button"
        tabindex="0"
        aria-label={`View details for ${project.title}`}
      >
        <img
          src={project.image}
          alt={project.title}
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          loading="lazy"
        />
        <div class="absolute inset-x-0 bottom-0 h-48 bg-gradient-to-t from-black/90 to-transparent" />

        <!-- Hover overlay -->
        <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-colors duration-500" />

        <!-- Play / info hint -->
        <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          <div class="w-16 h-16 rounded-full border-2 border-white/80 flex items-center justify-center backdrop-blur-sm bg-black/30">
            <svg class="w-6 h-6 text-white -translate-x-0.25" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z"/>
            </svg>
          </div>
        </div>

        <div class="absolute inset-0 p-8 md:p-12 flex flex-col justify-end pb-16 md:pb-20">
          {/* <p class="text-sm md:text-base text-gray-300">{project.category} &bull; {project.year}</p> */}
          <img
            src={project.logo}
            alt={project.title}
            class="h-8 md:h-10 w-auto object-contain object-left transition-transform duration-500 group-hover:-translate-y-1"
          />
        </div>

        <!-- More info button -->
        <div class="absolute bottom-8 right-8 md:bottom-12 md:right-12 opacity-0 group-hover:opacity-100 transition-all duration-300 translate-y-2 group-hover:translate-y-0">
          <button
            class="flex items-center gap-2 bg-white/10 hover:bg-white/20 backdrop-blur-sm border border-white/30 text-white text-sm font-semibold px-4 py-2 rounded-full transition-colors duration-200 more-info-btn"
            data-index={index}
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            More Info
          </button>
        </div>
      </div>
    ))}
  </div>
</section>

<!-- Modal Overlay -->
<div
  id="project-modal"
  class="fixed inset-0 z-50 hidden items-center justify-center p-4 md:p-8"
  role="dialog"
  aria-modal="true"
  aria-labelledby="modal-title"
>
  <!-- Backdrop -->
  <div id="modal-backdrop" class="absolute inset-0 bg-black/80 backdrop-blur-md opacity-0 transition-opacity duration-300"></div>

  <!-- Modal card -->
  <div
    id="modal-card"
    class="relative w-full max-w-3xl max-h-[90vh] overflow-hidden rounded-xl shadow-2xl opacity-0 scale-95 transition-all duration-300"
    style="background: #141414;"
  >
    <!-- Hero image area -->
    <div class="relative w-full h-64 md:h-80 overflow-hidden">
      <img
        id="modal-image"
        src=""
        alt=""
        class="w-full h-full object-cover"
      />
      <!-- Gradient overlay on image -->
      <div class="absolute inset-0 bg-gradient-to-t from-[#141414] via-[#141414]/20 to-transparent"></div>

      <!-- Logo overlaid on image -->
      <div class="absolute bottom-0 left-0 p-6 md:p-8">
        <img
          id="modal-logo"
          src=""
          alt=""
          class="h-24 md:h-32 w-auto object-contain object-left"
        />
      </div>

      <!-- Close button -->
      <button
        id="modal-close"
        class="absolute top-4 right-4 w-9 h-9 rounded-full bg-black/60 hover:bg-black/80 border border-white/20 flex items-center justify-center text-white transition-colors duration-200"
        aria-label="Close"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Content -->
    <div class="px-6 md:px-8 pb-8 pt-4 overflow-y-auto">
      <!-- Meta row -->
      <div class="flex items-center gap-3 mb-4 flex-wrap">
        <span id="modal-year" class="text-[#46d369] font-semibold text-sm tracking-wide"></span>
        <span class="w-1 h-1 rounded-full bg-gray-500"></span>
        <span id="modal-category" class="text-gray-400 text-sm border border-gray-600 px-2 py-0.5 rounded text-xs tracking-widest uppercase"></span>
      </div>

      <!-- Title -->
      <h2
        id="modal-title"
        class="text-2xl md:text-3xl font-black tracking-tight text-white mb-4"
      ></h2>

      <!-- Description -->
      <p id="modal-description" class="text-gray-300 text-sm md:text-base leading-relaxed"></p>

      <!-- Status badge -->
      <div class="mt-6 flex items-center gap-2">
        <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-amber-400 border border-amber-400/40 bg-amber-400/10 px-3 py-1.5 rounded-full">
          <span class="w-1.5 h-1.5 rounded-full bg-amber-400 animate-pulse"></span>
          In Development
        </span>
      </div>
    </div>
  </div>
</div>

<!-- Project data for JS -->
<script is:inline define:vars={{ projects }}>
  const cards = document.querySelectorAll('.project-card');
  const moreInfoBtns = document.querySelectorAll('.more-info-btn');
  const modal = document.getElementById('project-modal');
  const backdrop = document.getElementById('modal-backdrop');
  const card = document.getElementById('modal-card');
  const closeBtn = document.getElementById('modal-close');

  function openModal(index) {
    const p = projects[index];
    document.getElementById('modal-image').src = p.image;
    document.getElementById('modal-image').alt = p.title;
    document.getElementById('modal-logo').src = p.logo;
    document.getElementById('modal-logo').alt = p.title;
    document.getElementById('modal-title').textContent = p.title;
    document.getElementById('modal-year').textContent = p.year;
    document.getElementById('modal-category').textContent = p.category;
    document.getElementById('modal-description').textContent = p.description || '';

    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden';

    // Trigger animation
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        backdrop.style.opacity = '1';
        card.style.opacity = '1';
        card.style.transform = 'scale(1)';
      });
    });
  }

  function closeModal() {
    backdrop.style.opacity = '0';
    card.style.opacity = '0';
    card.style.transform = 'scale(0.95)';

    setTimeout(() => {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = '';
    }, 300);
  }

  // Open on card click
  cards.forEach((cardEl) => {
    cardEl.addEventListener('click', () => {
      openModal(parseInt(cardEl.dataset.index));
    });
    cardEl.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        openModal(parseInt(cardEl.dataset.index));
      }
    });
  });

  // More info buttons (stop propagation so it doesn't double-fire from card)
  moreInfoBtns.forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      openModal(parseInt(btn.dataset.index));
    });
  });

  // Close
  closeBtn.addEventListener('click', closeModal);
  backdrop.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
      closeModal();
    }
  });
</script>
