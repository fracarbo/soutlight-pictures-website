---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-black">
  <!-- Ambient glow -->
  <div class="absolute inset-0">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-amber-glow rounded-full blur-3xl animate-pulse"></div>
  </div>

  <!-- Dark overlay -->
  <div class="absolute inset-0 bg-gradient-to-b from-black via-transparent to-black"></div>

  <!-- Logo reveal -->
  <div class="relative z-10 text-center animate-fade-in flex flex-col items-center">
    <img src="/soutlight-pictures-website/logo.png" alt="SouthLight Pictures" class="w-64 md:w-[32rem] h-auto mx-auto" />
    <div class="w-12 h-[2px] bg-amber mx-auto mt-12 mb-12"></div>
    <a href="#contact" class="inline-block px-8 py-4 bg-amber text-black font-bold tracking-wider uppercase rounded-full hover:bg-amber-dark transition-colors shadow-[0_0_15px_rgba(255,191,0,0.5)] hover:shadow-[0_0_25px_rgba(255,191,0,0.7)] scale-100 hover:scale-105 duration-300">
      Contact Us
    </a>
  </div>
</section>

<style>
  @keyframes fade-in {
    0% {
      opacity: 0;
      transform: scale(0.95);
    }
    100% {
      opacity: 1;
      transform: scale(1);
    }
  }

  .animate-fade-in {
    animation: fade-in 2s ease-out forwards;
  }
</style>
