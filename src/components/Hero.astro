---

---

<section
  class="relative min-h-screen flex items-center justify-center overflow-hidden bg-black"
>
  <!-- Ambient glow -->
  <div class="absolute inset-0">
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-amber-glow rounded-full blur-3xl animate-pulse"
    >
    </div>
  </div>

  <!-- Dark overlay -->
  <div
    class="absolute inset-0 bg-gradient-to-b from-black via-transparent to-black"
  >
  </div>

  <!-- Logo reveal -->
  <div
    class="relative z-10 text-center animate-fade-in flex flex-col items-center"
  >
    <img
      src="/logo.png"
      alt="SouthLight Pictures"
      class="w-64 md:w-[32rem] h-auto mx-auto"
    />
  </div>
</section>

<style>
  @keyframes fade-in {
    0% {
      opacity: 0;
      transform: scale(0.95);
    }
    100% {
      opacity: 1;
      transform: scale(1);
    }
  }

  .animate-fade-in {
    animation: fade-in 2s ease-out forwards;
  }
</style>
